<Window x:Class="KVM.Tray.ConnectionApprovalDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Connection Request" Height="400" Width="500"
        WindowStartupLocation="CenterScreen" Topmost="True"
        ResizeMode="NoResize">
    <Border Padding="20" Background="#FFF0F0F0">
        <StackPanel>
            <!-- Header -->
            <TextBlock Text="🔔 Incoming Connection Request" 
                       FontSize="18" FontWeight="Bold" Margin="0,0,0,15"/>
            
            <!-- Client Info -->
            <Border Background="White" Padding="15" Margin="0,0,0,10" 
                    CornerRadius="5" BorderBrush="#FFDDDDDD" BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Client IP:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" x:Name="ClientIPText" Text="192.168.1.100"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Hostname:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" x:Name="HostnameText" Text="Unknown"/>
                    
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Protocol:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" x:Name="ProtocolText" Text="VNC"/>
                    
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Access:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" x:Name="AccessTypeText" Text="Full Control"/>
                    
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Time:" FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" x:Name="RequestTimeText" Text="14:32:15"/>
                </Grid>
            </Border>
            
            <!-- Security Info -->
            <StackPanel x:Name="GeoLocationPanel" Visibility="Collapsed" Margin="0,5">
                <TextBlock Text="📍 Location:" FontWeight="SemiBold"/>
                <TextBlock x:Name="GeoLocationText" Text="Unknown" Margin="10,2"/>
            </StackPanel>
            
            <TextBlock x:Name="AuthStatusText" Text="✓ Authenticated" 
                       Foreground="Green" FontWeight="SemiBold" Margin="0,5"/>
            
            <!-- Duration Selection -->
            <StackPanel Margin="0,15,0,10">
                <TextBlock Text="Approve for duration:" FontWeight="SemiBold"/>
                <ComboBox x:Name="DurationComboBox" Width="150" HorizontalAlignment="Left" Margin="0,5">
                    <ComboBoxItem Content="15 minutes" Tag="15"/>
                    <ComboBoxItem Content="30 minutes" Tag="30"/>
                    <ComboBoxItem Content="1 hour" Tag="60" IsSelected="True"/>
                    <ComboBoxItem Content="2 hours" Tag="120"/>
                    <ComboBoxItem Content="4 hours" Tag="240"/>
                    <ComboBoxItem Content="8 hours" Tag="480"/>
                </ComboBox>
            </StackPanel>
            
            <!-- Countdown -->
            <TextBlock x:Name="CountdownText" Text="Auto-reject in 30s" 
                       Foreground="Red" FontStyle="Italic" HorizontalAlignment="Center" Margin="0,10"/>
            
            <!-- Buttons -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button x:Name="ApproveButton" Content="✓ Approve" Width="100" Height="35" 
                        Background="#FF4CAF50" Foreground="White" FontWeight="Bold"
                        Click="ApproveButton_Click" Margin="0,0,10,0"/>
                
                <Button x:Name="RejectButton" Content="✗ Reject" Width="100" Height="35"
                        Background="#FFF44336" Foreground="White" FontWeight="Bold"
                        Click="RejectButton_Click" Margin="0,0,10,0"/>
                
                <Button x:Name="BlockPermanentlyButton" Content="🚫 Block" Width="100" Height="35"
                        Background="#FF9E9E9E" Foreground="White"
                        Click="BlockPermanentlyButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
